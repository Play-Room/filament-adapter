{
    "name": "playroom/filament-adapter",
    "description": "PlayRoom plugin and widget for Filament v5",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "filament/filament": "~5.0",
        "laravel/framework": "^13.0",
        "playroom/livewire-adapter": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "PlayRoom\\FilamentPlayRoom\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PlayRoom\\FilamentPlayRoom\\FilamentPlayRoomServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
